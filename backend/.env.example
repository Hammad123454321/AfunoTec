# ============================================================================
# ameer_nasr backend — environment variables (example)
# Copy to `.env` for local dev; never commit real values.
# ============================================================================

# ---- App ----
NODE_ENV=development
APP_NAME=ameer-nasr-backend
APP_PORT=4000
APP_HOST=0.0.0.0
APP_GLOBAL_PREFIX=api/v1
APP_CORS_ORIGINS=http://localhost:3000

# ---- Database (Postgres) ----
DATABASE_URL=postgresql://ameer:ameer@localhost:5432/ameer_nasr?schema=public

# ---- Redis (BullMQ + cache) ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT ----
JWT_ACCESS_SECRET=change-me-in-prod-access
JWT_ACCESS_TTL=900            # 15 minutes (in seconds)
JWT_REFRESH_SECRET=change-me-in-prod-refresh
JWT_REFRESH_TTL=604800        # 7 days (in seconds)

# ---- OTP ----
OTP_TTL_SECONDS=300           # 5 minutes
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5

# ---- File storage (Cloudflare R2 / any S3-compatible) ----
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=ameer-nasr-uploads
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# ---- Email (SMTP — provider chosen later) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="ameer_nasr <no-reply@example.com>"

# ---- Payment gateways (placeholders — adapters wired when client provides docs) ----
MVOLA_BASE_URL=
MVOLA_CONSUMER_KEY=
MVOLA_CONSUMER_SECRET=
MVOLA_PARTNER_NAME=
MVOLA_CALLBACK_URL=

AIRTEL_MONEY_BASE_URL=
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_CLIENT_SECRET=
AIRTEL_MONEY_CALLBACK_URL=

ORANGE_MONEY_BASE_URL=
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_CALLBACK_URL=

CARD_GATEWAY_BASE_URL=
CARD_GATEWAY_API_KEY=
CARD_GATEWAY_CALLBACK_URL=

# ---- AI (OUT OF SCOPE in current milestone — placeholder only) ----
AI_PROVIDER=
AI_API_KEY=

# ---- Misc ----
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100
LOG_LEVEL=debug
ENABLE_SWAGGER=true
SWAGGER_PATH=api/docs

# ---- Seed (initial admin) ----
SEED_ADMIN_EMAIL=admin@ameer-nasr.local
SEED_ADMIN_PASSWORD=ChangeMe!Admin#2026
SEED_ADMIN_NAME="System Admin"
