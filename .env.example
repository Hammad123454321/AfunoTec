# =============================================================================
#  ameer_nasr — root .env  (used by docker-compose.yml)
#
#  On the VPS:  cp .env.example .env  and fill in real values, then
#                docker compose up -d --build
#  Local dev :  the defaults inside docker-compose.yml already work, but
#                copying this file makes the values explicit.
#
#  Never commit a real .env — it is in .gitignore.
# =============================================================================

# ---- App env ----
NODE_ENV=production
# Comma-separated allow-list for CORS. While testing on an IP, include it too:
APP_CORS_ORIGINS=http://72.62.210.174,https://baodeals.com,https://www.baodeals.com

# ---- Public host ports (postgres/redis/backend stay on 127.0.0.1) ----
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=4000

# ---- Frontend binding ----
# How the frontend container is exposed on the host. Defaults to localhost:3000
# (intended for nginx-in-front mode). For the first deploy WITHOUT nginx /
# without a domain, bind directly to port 80 so http://<vps-ip>/ works:
FRONTEND_BIND=0.0.0.0:80
# Once nginx + cert are in place, switch back to:
# FRONTEND_BIND=127.0.0.1:3000

# ---- Postgres ----
POSTGRES_USER=ameer
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=ameer_nasr

# ---- JWT secrets (generate with: `openssl rand -hex 48`) ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ---- Default admin (seeded on first deploy; idempotent on later runs) ----
SEED_ADMIN_EMAIL=admin@baodeals.com
SEED_ADMIN_PASSWORD=ChangeMe!Admin#2026
SEED_ADMIN_NAME=System Admin

# ---- Frontend → backend URL (inlined into the Next.js bundle at build) ----
# While the backend has no public URL, point at the same VPS on port 4000
# (or leave blank — the frontend currently doesn't call the API yet).
NEXT_PUBLIC_API_URL=http://72.62.210.174:4000/api/v1
# Switch to https://api.baodeals.com/api/v1 once the API domain is live.

# ---- Anything below is optional / future ----
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# MAIL_FROM="ameer_nasr <no-reply@baodeals.com>"

# S3_ENDPOINT=
# S3_REGION=auto
# S3_BUCKET=
